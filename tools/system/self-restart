#!/bin/sh
# Self-restart: signals Docker to restart this container via socket API
CONTAINER=${OPENCLAW_CONTAINER_NAME:-kurtclaw-kurtclaw-1}
echo "Restarting container: $CONTAINER ..."
RESPONSE=$(curl -s --unix-socket /var/run/docker.sock -X POST "http://localhost/v1.44/containers/$CONTAINER/restart?t=10" -o /dev/null -w "%{http_code}")
if [ "$RESPONSE" = "204" ]; then
  echo "Restart signal sent successfully."
else
  echo "ERROR: Restart failed with HTTP $RESPONSE"
fi
